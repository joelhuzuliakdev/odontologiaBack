	@keyframes waPulse {
		0%, 100% { box-shadow: 0 8px 30px rgba(37,211,102,0.45); }
		50%       { box-shadow: 0 8px 40px rgba(37,211,102,0.75), 0 0 0 10px rgba(37,211,102,0.12); }
	}
	.wa-tooltip {
		position: absolute;
		left: calc(100% + 12px);
		top: 50%;
		transform: translateY(-50%);
		background: var(--charcoal);
		color: var(--white);
		font-size: 0.8rem;
		font-weight: 500;
