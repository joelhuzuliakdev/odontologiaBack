	═══════════════════════════════════════ */
	@media (max-width: 1024px) {
		/* Forzar clipping horizontal en todo el sitio */
		html, body { overflow-x: hidden; }

		/* from-left y from-right pasan a animar solo en Y */
		.reveal.from-left,
		.reveal.from-right {
			transform: translateY(40px);
		}
		.reveal.from-left.visible,
		.reveal.from-right.visible {
			transform: none;
		}
	}

