		opacity: 0;
		pointer-events: none;
		transition: opacity 0.25s;
	}
	.wa-tooltip::before {
		content: '';
		position: absolute;
		left: -5px; top: 50%;
		transform: translateY(-50%);
		border: 5px solid transparent;
		border-right-color: var(--charcoal);
